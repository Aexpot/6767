# ===========================================
# xOVPN Telegram Mini App - Environment Variables
# ===========================================

# ----- Supabase -----
# Supabase project URL and keys
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Telegram Bot -----
# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ----- Marzban VPN Panel -----
# Your Marzban panel URL (without trailing slash)
# Example: https://panel.yourdomain.com
MARZBAN_API_URL=https://your-marzban-panel.com

# Marzban admin credentials
# Create a sudo admin in Marzban for API access
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=your-secure-password

# ----- Pally Payment System -----
# Pally API credentials
# Get these from: https://pally.pro/dashboard
PALLY_SHOP_ID=your-shop-id
PALLY_API_KEY=your-api-key
PALLY_SECRET_KEY=your-secret-key

# Webhook URL for payment notifications
# Set this in Pally dashboard to: https://yourdomain.com/api/payment/webhook
PALLY_WEBHOOK_SECRET=your-webhook-secret

# ----- App Configuration -----
# Your app URL (for redirects)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Admin Telegram IDs (comma-separated)
# Users with these Telegram IDs will have admin access
ADMIN_TELEGRAM_IDS=123456789,987654321

# ===========================================
# How to set up:
# ===========================================
#
# 1. Supabase:
#    - Create a new Supabase project
#    - Copy URL and keys from Settings > API
#    - Run the SQL migrations in /scripts folder
#
# 2. Telegram Bot:
#    - Create a bot with @BotFather
#    - Enable Mini App in bot settings
#    - Set Mini App URL to your deployed app
#
# 3. Marzban:
#    - Install Marzban on your VPS
#    - Create admin account with API access
#    - Configure inbounds (VLESS, VMess, etc.)
#
# 4. Pally:
#    - Register at pally.pro
#    - Create a shop and get API credentials
#    - Set webhook URL in shop settings
#
# ===========================================
